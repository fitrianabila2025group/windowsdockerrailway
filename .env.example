# Dockur Windows on Railway — Environment Variables
# Copy this file or set these values in Railway Variables dashboard.

# Windows version to install (e.g., 2022, 11, 10, 2019, 2016)
VERSION=2022

# Windows administrator username
USERNAME=Admin

# Windows administrator password — CHANGE THIS!
PASSWORD=ChangeMe123

# RAM allocated to the virtual machine
RAM_SIZE=2G

# Number of CPU cores allocated
CPU_CORES=1

# Virtual disk size
DISK_SIZE=32G

# Windows region/locale
REGION=id-ID

# Keyboard layout
KEYBOARD=id-ID
